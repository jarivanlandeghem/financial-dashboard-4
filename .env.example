# Kopieer dit bestand naar .env en vul je echte waarden in
# .env wordt NOOIT naar GitHub gepusht (staat in .gitignore)

# Server
PORT=3001
FRONTEND_URL=http://localhost:5173

# Database pad (standaard: server/finance.db)
DB_PATH=./server/finance.db

# Bank API (KBC / Ponto / Isabel)
KBC_CLIENT_ID=
KBC_CLIENT_SECRET=
KBC_API_BASE_URL=

# Saxobank API
SAXO_APP_KEY=
SAXO_APP_SECRET=
SAXO_BASE_URL=https://gateway.saxobank.com/sim/openapi

# Bybit API
BYBIT_API_KEY=
BYBIT_API_SECRET=
